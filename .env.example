# ============================================================
# INVERSIONES BURSÁTILES — Variables de entorno
# Copiar como .env y completar con valores reales
# NUNCA subir el .env al repositorio (está en .gitignore)
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100xxxxxxxxxxxxxxx   # ID del grupo o tu chat personal

# --- Ejecución ---
# Hora de ejecución diaria en formato HH:MM (Argentina = UTC-3)
# Ej: cierre MERVAL ~18:30 ART = 21:30 UTC
RUN_TIME_UTC=21:30
TIMEZONE=America/Argentina/Buenos_Aires

# --- Dashboard ---
# URL pública donde estará hosteado el HTML generado
# Railway te da una URL del tipo: https://tu-app.up.railway.app
DASHBOARD_BASE_URL=https://tu-app.up.railway.app

# --- Google Drive (opcional, para subir el HTML automáticamente) ---
# Dejar vacío si no se usa
GDRIVE_FOLDER_ID=

# --- Control de features ---
SEND_EXCEL=true          # Enviar también el .xlsx por Telegram
SEND_ALERT_ON_CHANGE=true  # Alertar cuando cambia una señal vs día anterior
DEBUG_MODE=false
